---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Math Games"
			description="Interactive mathematical games and visualizations."
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="content">
				<h1>Math Games</h1>
				<p>
					Interactive games built around ideas from mathematics. Each one poses a real
					problem — your goal is to find a good solution.
				</p>
				<ul class="game-list">
					<li>
						<a href="/heilbronn">Heilbronn Triangle Game</a>
						<p>
							Place points inside a disk and try to maximize the area of the smallest
							triangle formed by any three of them. The more points you place, the
							harder it gets.
						</p>
					</li>
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 2rem 1rem 3rem;
	}

	.content h1 {
		margin-bottom: 1.25rem;
	}

	.content > p {
		line-height: 1.8;
		font-size: 1.05rem;
		margin-bottom: 2rem;
	}

	.game-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.game-list li {
		border-left: 3px solid var(--accent);
		padding-left: 1rem;
	}

	.game-list li a {
		font-size: 1.15rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
	}

	.game-list li a:hover {
		text-decoration: underline;
	}

	.game-list li p {
		margin: 0.3rem 0 0;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
	}
</style>
