---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import treesImg from '../assets/trees-looking-up.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<img src={treesImg.src} alt="Looking up through a canopy of trees" />
			</div>
			<div class="content">
				<h1>Welcome</h1>
				<p>
					Hello — I'm Dominic Day Kanerva. This site collects the things I care about
					professionally and personally: my academic research in mathematics, a running set
					of notes and tools built around topics in math that I find beautiful, and occasional
					writing on whatever is on my mind.
				</p>
				<p>
					The <a href="/research">Research</a> section has my publications, with links to
					the full papers. The <a href="/blog">Blog</a> is where I write more
					freely — about math, technology, and anything else worth thinking through slowly.
					There's also an <a href="/tools">Educational Tools</a> section in progress, where
					I'm building interactive visualizations and notebooks for mathematical ideas I want
					to make more accessible.
				</p>
				<p>
					Glad you're here.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 0 1rem 3rem;
	}

	.hero img {
		width: 100%;
		max-height: 420px;
		object-fit: cover;
		border-radius: 4px;
		margin-top: 1.5rem;
	}

	.content {
		padding-top: 2rem;
	}

	.content h1 {
		margin-bottom: 1.25rem;
	}

	.content p {
		line-height: 1.8;
		margin-bottom: 1.25rem;
		font-size: 1.05rem;
	}

	.content a {
		color: var(--accent);
	}
</style>
